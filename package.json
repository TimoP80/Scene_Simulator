{
  "name": "react-example",
  "private": true,
  "version": "0.3.2",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "A demoscene life-sim spanning 1985-2005. Recruit sceners, research effects, compile demos, and compete at parties.",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:electron": "concurrently -k -n vite,electron,host -c cyan,magenta,yellow \"cross-env VITE_DEV_SERVER_URL=http://localhost:3000 vite --port=3000 --host=0.0.0.0\" \"wait-on http://localhost:3000 dist-electron/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\" \"vite build -c electron.vite.config.ts --watch\"",
    "build": "vite build",
    "build:electron": "vite build -c electron.vite.config.ts",
    "build:all": "npm run bundle:worklet && vite build && vite build -c electron.vite.config.ts",
    "icons": "node scripts/generate-icons.mjs",
    "bundle:worklet": "node scripts/bundle-worklet.mjs",
    "dist:win": "node scripts/dist.mjs --win --x64",
    "dist:dir": "node scripts/dist.mjs --dir",
    "preview": "vite preview",
    "clean": "node -e \"['dist', 'server.js', 'dist-electron', 'public/worklets', 'release'].forEach(p => require('fs').rmSync(p, {recursive:true,force:true}))\"",
    "lint": "tsc --noEmit",
    "migrate:data": "tsx scripts/migrate_data_to_json.ts",
    "test:smoke": "tsx sim/__tests__/dispatchStampedEvent.smoke.ts",
    "test:audit-docs": "tsx sim/__tests__/audit-docs.smoke.ts",
    "test:load-during-import": "tsx sim/__tests__/loadDuringImport.smoke.ts",
    "test:economics": "tsx sim/__tests__/economicsView.smoke.ts",
    "test:replay": "tsx sim/__tests__/appendOnlyReplayDeterminism.smoke.ts",
    "test:migration": "tsx sim/__tests__/data_migration.smoke.ts",
    "test:music": "tsx electron/__tests__/musicLibrary.smoke.ts",
    "test:effect-unlocks": "tsx sim/__tests__/effectUnlocks.smoke.ts",
    "test:scoring": "tsx sim/__tests__/scoring.smoke.ts",
    "test:judging-profiles": "tsx sim/__tests__/judgingProfiles.smoke.ts",
    "test:artistic-directions": "tsx sim/__tests__/artisticDirections.smoke.ts",
    "test:effect-synergies": "tsx sim/__tests__/effectSynergies.smoke.ts",
    "test:hardware-catalog": "tsx sim/__tests__/hardwareCatalog.smoke.ts",
    "test:sponsorship-catalog": "tsx sim/__tests__/sponsorshipCatalog.smoke.ts",
    "test:technology-tree": "tsx sim/__tests__/technologyTree.smoke.ts",
    "test:software-catalog": "tsx sim/__tests__/softwareCatalog.smoke.ts",
    "test:demo-effects": "tsx sim/__tests__/demoEffects.smoke.ts",
    "test:initial-npcs": "tsx sim/__tests__/initialNpcs.smoke.ts",
    "test:initial-groups": "tsx sim/__tests__/initialGroups.smoke.ts",
    "test:party-calendar": "tsx sim/__tests__/partyCalendar.smoke.ts",
    "test:job-templates": "tsx sim/__tests__/jobTemplates.smoke.ts",
    "test:bbs-messages": "tsx sim/__tests__/bbsMessages.smoke.ts",
    "test:rival-releases": "tsx sim/__tests__/rivalReleases.smoke.ts",
    "test:platforms": "tsx sim/__tests__/platforms.smoke.ts",
    "test:all": "npm run test:smoke && npm run test:audit-docs && npm run test:load-during-import && npm run test:economics && npm run test:replay && npm run test:migration && npm run test:music && npm run test:effect-unlocks && npm run test:scoring && npm run test:judging-profiles && npm run test:artistic-directions && npm run test:effect-synergies && npm run test:hardware-catalog && npm run test:sponsorship-catalog && npm run test:technology-tree && npm run test:software-catalog && npm run test:demo-effects && npm run test:initial-npcs && npm run test:initial-groups && npm run test:party-calendar && npm run test:job-templates && npm run test:bbs-messages && npm run test:rival-releases && npm run test:platforms",
    "audit:docs": "node scripts/audit-docs.mjs",
    "capture:preview": "node scripts/capture-preview.mjs",
    "capture:preview:no-gif": "node scripts/capture-preview.mjs --no-gif",
    "capture:preview:hi-res": "node scripts/capture-preview.mjs --width 1920 --height 1080"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "chiptune3": "^0.8.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "ffmpeg-static": "^5.3.0",
    "puppeteer-core": "^25.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.tricyclecrews.demoscene",
    "productName": "Demoscene Simulator",
    "copyright": "Copyright (c) 1985-2026 Tricycle Crews",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{o,hprof,orig,pyc,pyo,rbc}",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}"
    ],
    "asar": true,
    "icon": "build/icon.png",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        },
        {
          "target": "portable",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Demoscene Simulator",
      "uninstallDisplayName": "${productName}",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}",
      "requestExecutionLevel": "user"
    },
    "electronVersion": "42.5.0"
  }
}
