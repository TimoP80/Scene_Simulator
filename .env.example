# GEMINI_API_KEY: Required for Gemini AI API calls (LLM narrative layer).
# The Electron wrapper prompts for this key on first launch and stores it
# in userData/settings.json. For a Vite-only dev run, export it here.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Optional override for the URL the simulator is served from.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
